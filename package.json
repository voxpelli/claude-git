{
  "private": true,
  "type": "module",
  "scripts": {
    "check": "run-p check:*",
    "check:plugin": "node validate-plugin.mjs",
    "check:md": "remark . --quiet --frail",
    "check:spec": "npx --yes skill-check check --no-security-scan",
    "check:portability": "node check-portability.mjs"
  },
  "devDependencies": {
    "js-yaml": "^4.1.0",
    "npm-run-all2": "^7.0.0",
    "remark-cli": "^12.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-preset-lint-consistent": "^6.0.0",
    "remark-preset-lint-recommended": "^7.0.0"
  },
  "remarkConfig": {
    "plugins": [
      "remark-frontmatter",
      "remark-preset-lint-consistent",
      "remark-preset-lint-recommended"
    ]
  }
}
